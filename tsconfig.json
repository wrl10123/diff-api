{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./static/js",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES6", "DOM"]
  },
  "include": [
    "static/js/**/*.js",
    "static/js/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/__pycache__/**"
  ],
  "typeAcquisition": {
    "enable": true,
    "include": ["sortablejs", "jsondiffpatch"]
  }
}