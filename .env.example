# DiffAPI 环境配置文件
# 复制此文件为 .env 并填写实际值

# Flask 环境 (development/production/testing)
FLASK_ENV=development

# 安全密钥 (生产环境必须更改)
SECRET_KEY=your-secret-key-change-in-production

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password-here
DB_NAME=diffapi

# 应用配置
HOST=127.0.0.1
PORT=5000
DEBUG=true

# 请求超时(秒)
REQUEST_TIMEOUT=30
